# =============================================================================
# Staddress AI API 設定
# =============================================================================
#
# 使い方:
#   1. このファイルを .env にコピーする
#      cp .env.example .env
#   2. 下記 STADDRESS_API_KEY に取得した API キーを設定する
#   3. curl サンプル等を実行する
#      ./examples/curl/staddress.sh -s "六本木ヒルズ 森タワー 52F"
#
# 公式 API ドキュメント: https://staddress.com/api
# =============================================================================

# API ベース URL（末尾に / は付けない）
STADDRESS_BASE_URL=https://api.staddress.com

# API キー（リクエストヘッダ X-Api-Key に付与されます）
#
# 【取得方法】
#
# ■ 無料プランで試す場合
#   1. Staddress AI にアカウント登録・ログイン
#      https://www.staddress.com/
#   2. アカウント管理画面（マイページ）を開く
#   3. 「API キー」欄でキーを確認・コピー
#      ※ 無料プランではベース URL も管理画面で確認できます
##
# 【注意】
#   - API キーは秘密情報です。.env を Git にコミットしないでください
#   - キーが無効・期限切れの場合、API は 401 unauthorized を返します
#   - 401 が出る場合: キーの typo、前後の空白、契約期間を確認してください
#
STADDRESS_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# 任意設定
# -----------------------------------------------------------------------------

# CLI 設定ファイルのパス（デフォルト: ~/.config/staddress/config）
# STADDRESS_CONFIG=/path/to/config

# リクエストタイムアウト（秒）
# STADDRESS_TIMEOUT=30
